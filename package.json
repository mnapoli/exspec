{
  "name": "@mnapoli/exspec",
  "version": "0.0.0",
  "description": "Executable specs - run Gherkin feature files with an AI agent in the browser",
  "type": "module",
  "bin": {
    "exspec": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && cp src/prompt-template.md dist/ && node scripts/add-shebang.js",
    "prepublishOnly": "npm run build",
    "dev": "tsx src/cli.ts",
    "fixtures": "npm run build && cd fixtures && node ../dist/cli.js --verbose",
    "test": "vitest run",
    "lint": "eslint src",
    "format": "prettier --write src",
    "format:check": "prettier --check src"
  },
  "keywords": [
    "gherkin",
    "bdd",
    "testing",
    "executable-specifications",
    "playwright",
    "ai",
    "claude",
    "browser-testing",
    "feature-tests"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mnapoli/exspec.git"
  },
  "homepage": "https://github.com/mnapoli/exspec",
  "bugs": {
    "url": "https://github.com/mnapoli/exspec/issues"
  },
  "author": "Matthieu Napoli",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@cucumber/gherkin": "^29.0.0",
    "@cucumber/messages": "^25.0.0",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@playwright/cli": "^0.1.1",
    "dotenv": "^16.4.0",
    "dotenv-expand": "^12.0.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tsx": "^4.0.0",
    "typescript": "^5.2.0",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0"
  }
}
